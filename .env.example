# ============================================================================
#  Ma'Maria — environment example. Copy to .env.local (dev) and set real values
#  on the host (Railway variables) for production. NEVER commit real secrets.
# ============================================================================

# --- Core ---
# Session signing key. Generate with:  openssl rand -hex 32
AUTH_SECRET=replace_with_random_32_byte_hex
NODE_ENV=production

# Where the SQLite database lives. On Railway point this at the mounted volume.
DATA_DIR=./data

# Public site URL (used for absolute links / metadata). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://example.com
APP_URL=https://example.com

# Display timezone for menu dates / cutoff logic.
APP_TIMEZONE=Europe/Chisinau

# Admin account (consumed by scripts/prod-reset.mjs to (re)set the admin login).
ADMIN_PHONE=admin
ADMIN_PASSWORD=replace_with_strong_password

# --- Phone OTP ---
# simulated      -> dev mode, code is logged/shown, no SMS sent, no cost
# twilio_verify  -> real SMS via Twilio Verify (requires the 3 TWILIO_* below)
OTP_PROVIDER=simulated
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram (menu posting) ---
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=@your_channel_or_-100_numeric_id

# --- Optional ---
# Override the logo used when rendering the menu image (defaults to public/logo.png).
# MENU_LOGO_PATH=
