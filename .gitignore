# dependencies & build output
node_modules/
.next/
out/
dist/
build/

# environment / secrets
.env
.env.local
.env.production
.env.*.local

# database (SQLite lives on a persistent volume in prod — never commit it)
data/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# generated / uploaded runtime assets
# NOTE: keep this scoped to public/generated — a bare "generated/" also matches
# source dirs like app/api/generated and would silently exclude them from git.
public/generated/
uploads/
tmp/
temp/

# OS junk
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# misc
.next-build/
.claude/
